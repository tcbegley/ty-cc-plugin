{
  "name": "ty-lsp",
  "description": "Python type checking via Astral's ty language server",
  "version": "0.1.0",
  "author": {
    "name": "tcbegley"
  },
  "lspServers": {
    "ty": {
      "command": "ty",
      "args": ["server"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  }
}
